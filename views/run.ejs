<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Territory Running - Run</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
    <link rel="stylesheet" href="/css/run.css">
</head>
<body>
    <div class="run-container">
        <div id="map" class="map-container"></div>
        
        <div class="control-panel">
            <div class="navbar-mini">
                <p class="header-title">Territory Running</p>
                <a href="/" class="back-link">← Back</a>
            </div>

            <div id="session-feedback" class="feedback"></div>

            <div class="run-info">
                <div class="info-item">
                    <span class="label">Distance:</span>
                    <span class="value" id="distance">0.00 km</span>
                </div>
                <div class="info-item">
                    <span class="label">Time:</span>
                    <span class="value" id="time">00:00:00</span>
                </div>
                <div class="info-item">
                    <span class="label">Calories:</span>
                    <span class="value" id="calories">0</span>
                </div>
            </div>

            <div class="control-buttons">
                <button class="btn btn-pause" id="pause-btn" onclick="pauseRun()">Pause</button>
                <button class="btn btn-finish" id="finish-btn" onclick="finishRun()">Finish</button>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="/js/run.js"></script>
</body>
</html>
